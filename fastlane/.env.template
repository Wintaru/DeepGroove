# App Store Connect API key credentials
# Copy this file to fastlane/.env and fill in your values.
# Get these from App Store Connect > Users & Access > Integrations > App Store Connect API
# Role required: App Manager (or Admin)
#
# Never commit fastlane/.env — it is gitignored.

ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_FILEPATH=~/private_keys/AuthKey_XXXXXXXXXX.p8
